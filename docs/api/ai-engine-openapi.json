        "properties": {
          "reference_vector": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Reference Vector"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "default": "Calibration successful"
          }
        },
        "type": "object",
        "required": [
          "reference_vector"
        ],
        "title": "CalibrationResult"
      },
      "ComparisonResult": {
        "properties": {
          "score": {
            "type": "number",
            "title": "Score"
          },
          "is_correct": {
